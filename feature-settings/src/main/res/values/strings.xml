    <string name="fill_blank_count_all">每题填空数：全部</string>
    <string name="fill_blank_count_template">每题填空数：%1$d</string>
    <string name="fill_question_generation_mode_label">动态填空出题模式：</string>
    <string name="fill_settings_show_help">查看详细说明</string>
    <string name="fill_settings_hide_help">隐藏详细说明</string>
    <string name="fill_mode_score_desc">高低分模式</string>
    <string name="fill_mode_score_asc">低高分模式</string>
    <string name="fill_mode_tag_random">标签随机模式</string>
    <string name="fill_mode_score_range_random">分值范围随机模式</string>
    <string name="fill_mode_full_answer">全答模式</string>
    <string name="fill_blank_help_text">按当前模式控制每题实际挖空数量；超出数量的答案会直接回填。</string>
    <string name="fill_mode_score_desc_help_text">按"每题填空数"从高分到低分依次出空；未被选中的答案会直接回填。</string>
    <string name="fill_mode_score_asc_help_text">按"每题填空数"从低分到高分依次出空；未被选中的答案会直接回填。</string>
    <string name="fill_mode_tag_random_help_text">只根据已选答案标签筛出可出空答案，再按"每题填空数"随机出空；分值范围在该模式下不参与出题。</string>
    <string name="fill_mode_score_range_random_help_text">先按分值范围和标签筛出可出空答案，再按"每题填空数"随机出空；如果该题没有命中范围的答案，则整题不出。</string>
    <string name="fill_mode_full_answer_help_text">先按分值范围和标签筛出可出空答案，再按"每题填空数"把同一题的可出空答案拆成多轮不重复出题；当前练习或考试本身的随机/顺序设置决定下一题顺序。</string>
    <string name="fill_full_answer_completion_label">全答完成条件：</string>
    <string name="fill_full_answer_completion_answered">全答</string>
    <string name="fill_full_answer_completion_correct">全答对</string>
    <string name="fill_full_answer_completion_help_text">仅对"全答模式"生效。全答表示同一词条下每道派生题都做答后就切到下一词条；全答对表示同一词条下若有答错题，会继续重复答错的空，直到该词条全部答对才切换。</string>
    <string name="fill_full_answer_order_label">全答轮次顺序：</string>
    <string name="fill_full_answer_order_random">同题内随机</string>
    <string name="fill_full_answer_order_sequential">同题内顺序</string>
    <string name="fill_full_answer_order_help_text">仅对"全答模式"生效。随机表示同一题命中的填空会先打乱再分轮出题；顺序表示按原题中的填空先后顺序依次分轮。</string>
    <string name="fill_answer_score_label">答案级别分值范围：</string>
    <string name="fill_answer_score_range_template">当前范围：%1$d-%2$d 分</string>
    <string name="fill_answer_score_help_text">仅对答案片段自带"【分类】【x分】"标记的动态填空生效。若整题没有任何答案命中这个范围，该题将不会进入本次练习或考试。</string>
    <string name="fill_answer_tag_filter_label">答案标签侧重练习：</string>
    <string name="fill_answer_tag_filter_placeholder">导入动态填空题库后，这里会显示可选标签。</string>
    <string name="fill_answer_tag_filter_help_text">留空表示不过滤。填写一个或多个标签关键字后，仅对匹配这些标签的答案片段优先出空；多个标签可用逗号、顿号或分号分隔。</string>
    <string name="fill_answer_tag_filter_clear">清除标签</string>
