{
  "name": "testapp-ai-proxy",
  "main": "src/index.ts",
  "compatibility_date": "2026-07-18",
  "compatibility_flags": ["nodejs_compat"],
  // Secrets（wrangler secret put）：DEEPSEEK_API_KEY, TAVILY_API_KEY,
  // GOOGLE_SERVICE_ACCOUNT_JSON, PLAY_CLOUD_PROJECT_NUMBER
  "vars": {
    "ALLOWED_PACKAGE_NAME": "com.example.testapp",
    "RATE_LIMIT_PER_MINUTE": "30"
  }
}
